<section class="auth-section register-page">
    <!-- Decorative Elements -->
    <div class="auth-decoration">
        <div class="decoration-circle decoration-circle--1"></div>
        <div class="decoration-circle decoration-circle--2"></div>
        <div class="decoration-line decoration-line--1"></div>
        <div class="decoration-line decoration-line--2"></div>
        <div class="decoration-grid"></div>
    </div>
    
    <div class="container">
        <div class="auth-card animate-fade-in-up">
            <div class="corner-br"></div>
            
            <div class="auth-brand">
                <a href="/" class="auth-logo">
                    <span class="auth-logo__text">CRYLOG</span>
                </a>
            </div>
            
            <div class="auth-header">
                <h1 class="auth-title">Crear Cuenta</h1>
                <p class="auth-subtitle">Únete a la comunidad</p>
            </div>
            
            <% if (errors && errors.length > 0) { %>
                <div class="form-errors animate-fade-in">
                    <% errors.forEach(error => { %>
                        <span class="form-error"><%= error.msg || error %></span>
                    <% }) %>
                </div>
            <% } %>
            
            <form action="/auth/register" method="POST" class="auth-form">
                <div class="form-group animate-fade-in-up stagger-1">
                    <label for="username" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        Nombre de Usuario
                    </label>
                    <input 
                        type="text" 
                        id="username" 
                        name="username" 
                        class="form-input" 
                        value="<%= formData.username || '' %>"
                        required
                        minlength="3"
                        maxlength="30"
                        placeholder="tu_usuario"
                        autocomplete="username"
                    >
                </div>
                
                <div class="form-group animate-fade-in-up stagger-2">
                    <label for="email" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        Email
                    </label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        class="form-input" 
                        value="<%= formData.email || '' %>"
                        required
                        placeholder="tu@email.com"
                        autocomplete="email"
                    >
                </div>
                
                <div class="form-group animate-fade-in-up stagger-3">
                    <label for="password" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        Contraseña
                    </label>
                    <div class="password-input-wrapper">
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            class="form-input" 
                            required
                            minlength="6"
                            placeholder="Mínimo 6 caracteres"
                            autocomplete="new-password"
                        >
                        <button type="button" class="password-toggle" onclick="togglePassword('password')" aria-label="Mostrar contraseña">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </div>
                </div>
                
                <div class="form-group animate-fade-in-up stagger-4">
                    <label for="passwordConfirm" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        Confirmar Contraseña
                    </label>
                    <div class="password-input-wrapper">
                        <input 
                            type="password" 
                            id="passwordConfirm" 
                            name="passwordConfirm" 
                            class="form-input" 
                            required
                            placeholder="Repite tu contraseña"
                            autocomplete="new-password"
                        >
                        <button type="button" class="password-toggle" onclick="togglePassword('passwordConfirm')" aria-label="Mostrar contraseña">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </div>
                </div>
                
                <button type="submit" class="btn btn--primary btn--full auth-submit animate-fade-in-up stagger-5">
                    <span>Crear Cuenta</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </button>
            </form>
            
            <div class="auth-divider">
                <span>o</span>
            </div>
            
            <div class="auth-footer animate-fade-in-up stagger-6">
                <p class="auth-footer__text">¿Ya tienes cuenta?</p>
                <a href="/auth/login" class="btn btn--secondary btn--full">
                    Iniciar Sesión
                </a>
            </div>
        </div>
    </div>
</section>

<style>
/* ============================================
   REGISTER PAGE - Design System Neo-Editorial
   ============================================ */

.register-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: var(--spacing-lg) 0;
    background: var(--surface);
}

/* Decorative Elements - Pure CSS */
.auth-decoration {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 0;
}

.decoration-circle {
    position: absolute;
    border-radius: 50%;
    border: 0.5px solid var(--outline-variant);
}

.decoration-circle--1 {
    width: 600px;
    height: 600px;
    top: -200px;
    right: -200px;
    border-color: rgba(233, 255, 186, 0.15);
    animation: rotate 60s linear infinite;
}

.decoration-circle--2 {
    width: 400px;
    height: 400px;
    bottom: -100px;
    left: -100px;
    border-color: rgba(201, 124, 255, 0.15);
    animation: rotate 45s linear infinite reverse;
}

.decoration-line {
    position: absolute;
    background: linear-gradient(90deg, transparent, var(--outline-variant), transparent);
    height: 0.5px;
}

.decoration-line--1 {
    width: 50%;
    top: 30%;
    left: 0;
}

.decoration-line--2 {
    width: 50%;
    bottom: 30%;
    right: 0;
}

.decoration-grid {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
        linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 100px 100px;
    opacity: 0.5;
}

/* Main Card */
.auth-card {
    position: relative;
    z-index: 1;
    background: var(--surface-container);
    border: 0.5px solid var(--outline);
    padding: var(--spacing-xl) var(--spacing-lg);
    max-width: 420px;
    width: 100%;
    margin: 0 auto;
    box-shadow: 
        0 30px 60px rgba(0, 0, 0, 0.4),
        0 0 0 1px rgba(255, 255, 255, 0.05) inset;
}

/* Card Top Accent Line */
.auth-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, 
        transparent 0%, 
        var(--primary) 20%, 
        var(--secondary) 50%, 
        var(--primary) 80%, 
        transparent 100%
    );
}

/* Card Corner Accents */
.auth-card::after {
    content: '';
    position: absolute;
    top: -5px;
    left: -5px;
    width: 30px;
    height: 30px;
    border-top: 1px solid var(--primary);
    border-left: 1px solid var(--primary);
}

/* Extra corner decoration */
.auth-card .corner-br {
    position: absolute;
    bottom: -5px;
    right: -5px;
    width: 30px;
    height: 30px;
    border-bottom: 1px solid var(--primary);
    border-right: 1px solid var(--primary);
}

.auth-card > * {
    position: relative;
    z-index: 2;
}

/* Typography */
.auth-brand {
    text-align: center;
    margin-bottom: var(--spacing-lg);
}

.auth-logo {
    display: inline-block;
}

.auth-logo__text {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--primary);
    letter-spacing: 0.05em;
}

.auth-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
}

.auth-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
    color: var(--on-surface);
}

.auth-subtitle {
    font-size: 0.875rem;
    color: var(--on-surface-variant);
}

/* Form Elements */
.auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-utility);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--on-surface-variant);
}

.form-label svg {
    color: var(--on-surface-variant);
}

.form-input {
    background: var(--surface-container-high);
    border: 0.5px solid var(--outline);
    padding: 14px 16px;
    font-size: 0.95rem;
    color: var(--on-surface);
    transition: all 0.2s ease;
    font-family: var(--font-body);
}

.form-input::placeholder {
    color: var(--on-surface-variant);
    opacity: 0.5;
}

.form-input:hover {
    border-color: var(--outline-variant);
}

.form-input:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--surface-container-highest);
}

/* Password Toggle */
.password-input-wrapper {
    position: relative;
}

.password-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--on-surface-variant);
    cursor: pointer;
    padding: 4px;
    opacity: 0.6;
    transition: opacity 0.2s ease;
}

.password-toggle:hover {
    opacity: 1;
    color: var(--primary);
}

/* Submit Button */
.auth-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: var(--spacing-sm);
    background: var(--primary);
    color: var(--surface);
    border: none;
    padding: 14px 24px;
    font-family: var(--font-utility);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
}

.auth-submit:hover {
    background: var(--primary-container);
    box-shadow: 0 0 20px rgba(233, 255, 186, 0.3);
}

/* Divider */
.auth-divider {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin: var(--spacing-md) 0;
    color: var(--on-surface-variant);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}

.auth-divider::before,
.auth-divider::after {
    content: '';
    flex: 1;
    height: 0.5px;
    background: var(--outline);
}

/* Footer */
.auth-footer {
    text-align: center;
}

.auth-footer__text {
    font-size: 0.875rem;
    color: var(--on-surface-variant);
    margin-bottom: var(--spacing-sm);
}

/* Errors */
.form-errors {
    background: rgba(255, 68, 68, 0.08);
    border: 0.5px solid rgba(255, 68, 68, 0.3);
    padding: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.form-error {
    font-size: 0.875rem;
    color: #ff6b6b;
}

/* Animation */
@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Tablet */
@media (max-width: 768px) {
    .register-page .container {
        max-width: 100%;
        padding: 0 var(--spacing-md);
    }
}

/* Mobile */
@media (max-width: 480px) {
    .register-page {
        padding: var(--spacing-sm);
        align-items: flex-start;
        padding-top: 80px;
        padding-bottom: var(--spacing-lg);
    }
    
    .register-page .container {
        padding: 0;
        width: 100%;
    }
    
    .auth-card {
        padding: var(--spacing-lg) var(--spacing-md);
        margin: 0;
        max-width: 100%;
        width: 100%;
    }
    
    .corner-br {
        display: none;
    }
    
    .auth-card::after {
        width: 20px;
        height: 20px;
    }
    
    .auth-logo__text {
        font-size: 1.5rem;
    }
    
    .auth-title {
        font-size: 1.25rem;
    }
    
    .form-input {
        padding: 12px 14px;
    }
    
    .decoration-circle--1,
    .decoration-circle--2 {
        display: none;
    }
    
    .decoration-line--1,
    .decoration-line--2 {
        display: none;
    }
}
</style>

<script>
function togglePassword(inputId) {
    const passwordInput = document.getElementById(inputId);
    const button = event.currentTarget;
    const svg = button.querySelector('svg');
    
    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        svg.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
    } else {
        passwordInput.type = 'password';
        svg.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
    }
}
</script>
