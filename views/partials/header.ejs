<header class="header glass-nav" id="main-header">
    <div class="container">
        <nav class="nav">
            <a href="/" class="nav__logo animate-fade-in">
                <span class="nav__logo-text">CRYLOG</span>
            </a>
            
            <div class="nav__links" id="nav-links">
                <a href="/posts" class="nav__link">Posts</a>
                <a href="/about" class="nav__link">Sobre Nosotros</a>
                
                <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
                    <a href="/posts/create" class="nav__link">Crear Post</a>
                    <a href="/posts/my-posts" class="nav__link">Mis Posts</a>
                    
                    <div class="nav__user">
                        <span class="nav__username"><%= user.username %></span>
                        <a href="/auth/logout" class="nav__link nav__logout">Cerrar Sesión</a>
                    </div>
                <% } else { %>
                    <a href="/auth/login" class="nav__link">Iniciar Sesión</a>
                    <a href="/auth/register" class="btn btn--primary">Registrarse</a>
                <% } %>
            </div>
            
            <button class="nav__toggle" id="nav-toggle" aria-label="Menu" type="button">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
    </div>
</header>
