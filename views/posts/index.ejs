<% if (typeof homePage !== 'undefined' && homePage) { %>
<!-- Hero Section -->
<section class="hero">
    <div class="container">
        <div class="hero__content">
            <h1 class="hero__title gradient-text-animated">
                CRYLOG
            </h1>
            <p class="hero__subtitle">
                Neo-Editorial Excellence<br>
                Explora ideas que desafían lo convencional
            </p>
            <div class="hero__cta">
                <a href="/posts/create" class="btn btn--primary btn--large">
                    Crear Post
                </a>
                <a href="/posts" class="btn btn--secondary btn--large" style="margin-left: 1rem;">
                    Explorar
                </a>
            </div>
        </div>
        <div class="scroll-indicator"></div>
    </div>
</section>
<% } %>

<section class="posts-section">
    <div class="container">
        <!-- Header -->
        <header class="section-header <%= (typeof homePage !== 'undefined' && homePage) ? 'animate-fade-in-up' : '' %>">
            <h1 class="display-lg <%= (typeof homePage !== 'undefined' && homePage) ? 'gradient-text' : '' %>">
                <% if (typeof myPosts !== 'undefined' && myPosts) { %>
                    Mis Posts
                <% } else if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                    Búsqueda: <%= searchQuery %>
                <% } else if (typeof currentCategory !== 'undefined' && currentCategory) { %>
                    Categoría: <%= currentCategory %>
                <% } else if (typeof homePage !== 'undefined' && homePage) { %>
                    Publicaciones Recientes
                <% } else { %>
                    Todos los Posts
                <% } %>
            </h1>
            <p class="section-description <%= (typeof homePage !== 'undefined' && homePage) ? 'animate-fade-in-up stagger-1' : '' %>">
                <%= pagination.total %> publicaciones encontradas
            </p>
        </header>
        
        <!-- Filtros -->
        <div class="filters">
            <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                <div class="filter-group">
                    <span class="filter-label">Categorías:</span>
                    <a href="/posts" class="filter-tag <%= !currentCategory ? 'active' : '' %>">Todas</a>
                    <% categories.forEach(cat => { %>
                        <a href="/posts?category=<%= encodeURIComponent(cat) %>" class="filter-tag <%= currentCategory === cat ? 'active' : '' %>">
                            <%= cat %>
                        </a>
                    <% }) %>
                </div>
            <% } %>
            
            <form action="/posts" method="GET" class="search-form">
                <input 
                    type="search" 
                    name="search" 
                    placeholder="Buscar posts..."
                    value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                    class="search-input"
                >
                <button type="submit" class="btn btn--secondary">Buscar</button>
            </form>
        </div>
        
        <!-- Grid de Posts -->
        <% if (posts && posts.length > 0) { %>
            <div class="posts-grid">
                <% posts.forEach((post, index) => { %>
                    <article class="post-card animate-fade-in-up stagger-<%= Math.min(index + 1, 5) %>">
                        <% if (post.featured_image) { %>
                            <a href="/posts/slug/<%= post.slug %>" class="post-card__image">
                                <img src="<%= post.featured_image %>" alt="<%= post.title %>">
                            </a>
                        <% } %>
                        
                        <div class="post-card__content">
                            <% if (post.category) { %>
                                <span class="post-card__category"><%= post.category %></span>
                            <% } %>
                            
                            <h2 class="post-card__title">
                                <a href="/posts/slug/<%= post.slug %>"><%= post.title %></a>
                            </h2>
                            
                            <p class="post-card__excerpt"><%= post.excerpt %></p>
                            
                            <div class="post-card__meta">
                                <span class="post-card__author">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="12" cy="7" r="4"></circle>
                                    </svg>
                                    <%= post.author ? post.author.username : 'Anónimo' %>
                                </span>
                                <span class="post-card__date">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="16" y1="2" x2="16" y2="6"></line>
                                        <line x1="8" y1="2" x2="8" y2="6"></line>
                                        <line x1="3" y1="10" x2="21" y2="10"></line>
                                    </svg>
                                    <%= new Date(post.created_at).toLocaleDateString('es-ES', { 
                                        year: 'numeric', 
                                        month: 'short',
                                        day: 'numeric' 
                                    }) %>
                                </span>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
            
            <!-- Paginación -->
            <% if (pagination.totalPages > 1) { %>
                <nav class="pagination">
                    <% if (pagination.page > 1) { %>
                        <a href="/posts?page=<%= pagination.page - 1 %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="pagination__link">
                            ← Anterior
                        </a>
                    <% } %>
                    
                    <span class="pagination__info">
                        Página <%= pagination.page %> de <%= pagination.totalPages %>
                    </span>
                    
                    <% if (pagination.page < pagination.totalPages) { %>
                        <a href="/posts?page=<%= pagination.page + 1 %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" class="pagination__link">
                            Siguiente →
                        </a>
                    <% } %>
                </nav>
            <% } %>
        <% } else { %>
            <div class="empty-state">
                <p class="empty-state__text">No se encontraron posts.</p>
                <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
                    <a href="/posts/create" class="btn btn--primary">Crear tu primer post</a>
                <% } %>
            </div>
        <% } %>
    </div>
</section>
