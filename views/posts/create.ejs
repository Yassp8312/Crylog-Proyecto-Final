<section class="post-form-section create-post-page">
    <!-- Decorative Elements -->
    <div class="auth-decoration">
        <div class="decoration-circle decoration-circle--1"></div>
        <div class="decoration-circle decoration-circle--2"></div>
        <div class="decoration-line decoration-line--1"></div>
        <div class="decoration-line decoration-line--2"></div>
        <div class="decoration-grid"></div>
    </div>
    
    <div class="container">
        <div class="form-card animate-fade-in-up">
            <div class="corner-br"></div>
            
            <div class="form-brand">
                <a href="/" class="form-logo">
                    <span class="form-logo__text">CRYLOG</span>
                </a>
            </div>
            
            <div class="form-header">
                <h1 class="form-title">Crear Nuevo Post</h1>
                <p class="form-subtitle">Comparte tu idea con la comunidad</p>
            </div>
            
            <% if (errors && errors.length > 0) { %>
                <div class="form-errors animate-fade-in">
                    <% errors.forEach(error => { %>
                        <span class="form-error"><%= error.msg || error %></span>
                    <% }) %>
                </div>
            <% } %>
            
            <form action="/posts/create" method="POST" class="post-form">
                <div class="form-group animate-fade-in-up stagger-1">
                    <label for="title" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="4" y1="9" x2="20" y2="9"></line>
                            <line x1="4" y1="15" x2="20" y2="15"></line>
                            <line x1="10" y1="3" x2="8" y2="21"></line>
                            <line x1="16" y1="3" x2="14" y2="21"></line>
                        </svg>
                        Título *
                    </label>
                    <input 
                        type="text" 
                        id="title" 
                        name="title" 
                        class="form-input form-input--lg"
                        value="<%= formData.title || '' %>"
                        required
                        maxlength="200"
                        placeholder="Título de tu post"
                        autocomplete="off"
                    >
                </div>
                
                <div class="form-row">
                    <div class="form-group form-group--half animate-fade-in-up stagger-2">
                        <label for="category" class="form-label">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                            </svg>
                            Categoría
                        </label>
                        <input 
                            type="text" 
                            id="category" 
                            name="category" 
                            class="form-input"
                            value="<%= formData.category || '' %>"
                            maxlength="50"
                            placeholder="ej. Tecnología, Diseño, Arte"
                        >
                    </div>
                    
                    <div class="form-group form-group--half animate-fade-in-up stagger-2">
                        <label for="tags" class="form-label">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                <line x1="7" y1="7" x2="7.01" y2="7"></line>
                            </svg>
                            Tags
                        </label>
                        <input 
                            type="text" 
                            id="tags" 
                            name="tags" 
                            class="form-input"
                            value="<%= formData.tags || '' %>"
                            placeholder="tag1, tag2, tag3"
                        >
                    </div>
                </div>
                
                <div class="form-group animate-fade-in-up stagger-3">
                    <label for="featured_image" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                        URL de imagen destacada
                    </label>
                    <input 
                        type="url" 
                        id="featured_image" 
                        name="featured_image" 
                        class="form-input"
                        value="<%= formData.featured_image || '' %>"
                        placeholder="https://ejemplo.com/imagen.jpg"
                    >
                </div>
                
                <div class="form-group animate-fade-in-up stagger-4">
                    <label for="excerpt" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="8" y1="6" x2="21" y2="6"></line>
                            <line x1="8" y1="12" x2="21" y2="12"></line>
                            <line x1="8" y1="18" x2="21" y2="18"></line>
                            <line x1="3" y1="6" x2="3.01" y2="6"></line>
                            <line x1="3" y1="12" x2="3.01" y2="12"></line>
                            <line x1="3" y1="18" x2="3.01" y2="18"></line>
                        </svg>
                        Extracto (resumen)
                    </label>
                    <textarea 
                        id="excerpt" 
                        name="excerpt" 
                        class="form-input"
                        rows="3"
                        maxlength="300"
                        placeholder="Breve resumen de tu post (opcional, se genera automáticamente si se deja vacío)"
                    ><%= formData.excerpt || '' %></textarea>
                </div>
                
                <div class="form-group animate-fade-in-up stagger-5">
                    <label for="content" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                        Contenido *
                    </label>
                    <textarea 
                        id="content" 
                        name="content" 
                        class="form-input form-input--editor"
                        rows="12"
                        required
                        minlength="10"
                        placeholder="Escribe tu contenido aquí... (HTML permitido)"
                    ><%= formData.content || '' %></textarea>
                </div>
                
                <div class="form-group animate-fade-in-up stagger-6">
                    <label for="status" class="form-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                        Estado
                    </label>
                    <div class="select-wrapper">
                        <select id="status" name="status" class="form-select">
                            <option value="published" <%= formData.status === 'published' ? 'selected' : '' %>>🟢 Publicado</option>
                            <option value="draft" <%= formData.status === 'draft' ? 'selected' : '' %>>📝 Borrador</option>
                        </select>
                        <svg class="select-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                </div>
                
                <div class="form-actions animate-fade-in-up stagger-7">
                    <button type="submit" class="btn btn--primary btn--full auth-submit">
                        <span>Publicar Post</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                    </button>
                    <a href="/posts" class="btn btn--secondary btn--full">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

<style>
/* ============================================
   CREATE POST PAGE - Design System Neo-Editorial
   ============================================ */

.create-post-page {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    padding: var(--spacing-lg) 0;
    background: var(--surface);
}

/* Decorative Elements - Same as login */
.auth-decoration {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 0;
}

.decoration-circle {
    position: absolute;
    border-radius: 50%;
    border: 0.5px solid var(--outline-variant);
}

.decoration-circle--1 {
    width: 600px;
    height: 600px;
    top: -200px;
    right: -200px;
    border-color: rgba(233, 255, 186, 0.15);
    animation: rotate 60s linear infinite;
}

.decoration-circle--2 {
    width: 400px;
    height: 400px;
    bottom: -100px;
    left: -100px;
    border-color: rgba(201, 124, 255, 0.15);
    animation: rotate 45s linear infinite reverse;
}

.decoration-line {
    position: absolute;
    background: linear-gradient(90deg, transparent, var(--outline-variant), transparent);
    height: 0.5px;
}

.decoration-line--1 {
    width: 50%;
    top: 30%;
    left: 0;
}

.decoration-line--2 {
    width: 50%;
    bottom: 30%;
    right: 0;
}

.decoration-grid {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
        linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 100px 100px;
    opacity: 0.5;
}

/* Main Card */
.form-card {
    position: relative;
    z-index: 1;
    background: var(--surface-container);
    border: 0.5px solid var(--outline);
    padding: var(--spacing-xl) var(--spacing-lg);
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    box-shadow: 
        0 30px 60px rgba(0, 0, 0, 0.4),
        0 0 0 1px rgba(255, 255, 255, 0.05) inset;
}

/* Card Top Accent Line */
.form-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, 
        transparent 0%, 
        var(--primary) 20%, 
        var(--secondary) 50%, 
        var(--primary) 80%, 
        transparent 100%
    );
}

/* Card Corner Accents */
.form-card::after {
    content: '';
    position: absolute;
    top: -5px;
    left: -5px;
    width: 30px;
    height: 30px;
    border-top: 1px solid var(--primary);
    border-left: 1px solid var(--primary);
}

.form-card .corner-br {
    position: absolute;
    bottom: -5px;
    right: -5px;
    width: 30px;
    height: 30px;
    border-bottom: 1px solid var(--primary);
    border-right: 1px solid var(--primary);
}

.form-card > * {
    position: relative;
    z-index: 2;
}

/* Typography */
.form-brand {
    text-align: center;
    margin-bottom: var(--spacing-md);
}

.form-logo {
    display: inline-block;
}

.form-logo__text {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--primary);
    letter-spacing: 0.05em;
}

.form-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 0.5px solid var(--outline);
}

.form-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
    color: var(--on-surface);
}

.form-subtitle {
    font-size: 0.875rem;
    color: var(--on-surface-variant);
}

/* Form Elements */
.post-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-utility);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--on-surface-variant);
}

.form-label svg {
    color: var(--on-surface-variant);
}

.form-input {
    background: var(--surface-container-high);
    border: 0.5px solid var(--outline);
    padding: 14px 16px;
    font-size: 0.95rem;
    color: var(--on-surface);
    transition: all 0.2s ease;
    font-family: var(--font-body);
    width: 100%;
}

.form-input::placeholder {
    color: var(--on-surface-variant);
    opacity: 0.5;
}

.form-input:hover {
    border-color: var(--outline-variant);
}

.form-input:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--surface-container-highest);
}

.form-input--lg {
    font-size: 1.1rem;
    font-family: var(--font-display);
}

.form-input--editor {
    font-family: var(--font-mono, 'Courier New', monospace);
    line-height: 1.6;
}

/* Select Styling */
.select-wrapper {
    position: relative;
    width: 100%;
}

.form-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background: var(--surface-container-high);
    border: 0.5px solid var(--outline);
    padding: 14px 40px 14px 16px;
    font-size: 0.95rem;
    color: var(--on-surface);
    cursor: pointer;
    width: 100%;
    font-family: var(--font-body);
    transition: all 0.2s ease;
}

.form-select:hover {
    border-color: var(--outline-variant);
}

.form-select:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--surface-container-highest);
}

.select-arrow {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--on-surface-variant);
}

/* Form Row */
.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
}

.form-group--half {
    width: 100%;
}

/* Actions */
.form-actions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 0.5px solid var(--outline);
}

.auth-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--primary);
    color: var(--surface);
    border: none;
    padding: 14px 24px;
    font-family: var(--font-utility);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
}

.auth-submit:hover {
    background: var(--primary-container);
    box-shadow: 0 0 20px rgba(233, 255, 186, 0.3);
}

/* Errors */
.form-errors {
    background: rgba(255, 68, 68, 0.08);
    border: 0.5px solid rgba(255, 68, 68, 0.3);
    padding: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.form-error {
    font-size: 0.875rem;
    color: #ff6b6b;
}

/* Animation */
@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Tablet */
@media (max-width: 768px) {
    .form-card {
        padding: var(--spacing-lg) var(--spacing-md);
        margin: var(--spacing-sm);
    }
    
    .form-row {
        grid-template-columns: 1fr;
    }
}

/* Mobile */
@media (max-width: 480px) {
    .create-post-page {
        padding: var(--spacing-sm);
        padding-top: 80px;
    }
    
    .form-card {
        padding: var(--spacing-lg) var(--spacing-md);
        margin: 0;
        max-width: 100%;
        width: 100%;
    }
    
    .corner-br {
        display: none;
    }
    
    .form-card::after {
        width: 20px;
        height: 20px;
    }
    
    .form-logo__text {
        font-size: 1.5rem;
    }
    
    .form-title {
        font-size: 1.25rem;
    }
    
    .form-input {
        padding: 12px 14px;
    }
    
    .decoration-circle--1,
    .decoration-circle--2 {
        display: none;
    }
}
</style>
