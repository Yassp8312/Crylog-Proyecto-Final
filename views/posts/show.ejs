<article class="post-detail animate-fade-in">
    <!-- Hero Section -->
    <% if (post.featured_image) { %>
        <div class="post-hero animate-fade-in">
            <img src="<%= post.featured_image %>" alt="<%= post.title %>" class="post-hero__image">
            <div class="post-hero__overlay"></div>
            <div class="post-hero__accent"></div>
        </div>
    <% } %>
    
    <div class="container">
        <div class="post-detail__card">
            <div class="corner-accent corner-accent--tl"></div>
            <div class="corner-accent corner-accent--br"></div>
            
            <header class="post-header animate-fade-in-up">
                <% if (post.category) { %>
                    <span class="post-category animate-fade-in-up stagger-1">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                        </svg>
                        <%= post.category %>
                    </span>
                <% } %>
                
                <h1 class="post-detail__title animate-fade-in-up stagger-2"><%= post.title %></h1>
                
                <div class="post-meta">
                    <div class="post-meta__item">
                        <span class="post-meta__icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </span>
                        <span class="post-meta__label">Por</span>
                        <span class="post-meta__value post-meta__value--highlight"><%= post.author ? post.author.username : 'Anónimo' %></span>
                    </div>
                    
                    <div class="post-meta__divider"></div>
                    
                    <div class="post-meta__item">
                        <span class="post-meta__icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                        </span>
                        <span class="post-meta__label">Publicado</span>
                        <span class="post-meta__value">
                            <%= new Date(post.created_at).toLocaleDateString('es-ES', { 
                                year: 'numeric', 
                                month: 'long', 
                                day: 'numeric' 
                            }) %>
                        </span>
                    </div>
                    
                    <% if (post.updated_at && post.updated_at !== post.created_at) { %>
                        <div class="post-meta__divider"></div>
                        <div class="post-meta__item">
                            <span class="post-meta__icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polygon points="14 2 18 6 7 17 3 17 3 13 14 2"></polygon>
                                    <line x1="3" y1="22" x2="21" y2="22"></line>
                                </svg>
                            </span>
                            <span class="post-meta__label">Actualizado</span>
                            <span class="post-meta__value">
                                <%= new Date(post.updated_at).toLocaleDateString('es-ES', { 
                                    year: 'numeric', 
                                    month: 'long', 
                                    day: 'numeric' 
                                }) %>
                            </span>
                        </div>
                    <% } %>
                </div>
                
                <!-- Acciones del autor/admin -->
                <% if (typeof isAuthor !== 'undefined' && isAuthor) { %>
                    <div class="post-actions">
                        <a href="/posts/<%= post.id %>/edit" class="btn btn--secondary">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            Editar
                        </a>
                        <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" class="inline-form" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este post?');">
                            <button type="submit" class="btn btn--danger">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                                Eliminar
                            </button>
                        </form>
                    </div>
                <% } %>
            </header>
            
            <!-- Tags -->
            <% if (post.tags && post.tags.length > 0) { %>
                <div class="post-tags">
                    <% post.tags.forEach((tag, index) => { %>
                        <span class="post-tag animate-fade-in-up" style="animation-delay: <%= index * 0.1 %>s; -webkit-animation-delay: <%= index * 0.1 %>s;">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                <line x1="7" y1="7" x2="7.01" y2="7"></line>
                            </svg>
                            <%= tag %>
                        </span>
                    <% }) %>
                </div>
            <% } %>
            
            <!-- Content -->
            <div class="post-detail__content animate-fade-in-up stagger-3">
                <%- post.content %>
            </div>
            
            <!-- Navigation -->
            <nav class="post-navigation">
                <a href="/posts" class="btn btn--tertiary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Volver a posts
                </a>
                
                <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
                    <a href="/posts/create" class="btn btn--primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Crear nuevo post
                    </a>
                <% } %>
            </nav>
        </div>
    </div>
</article>
